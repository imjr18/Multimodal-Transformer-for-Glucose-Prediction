# ============================================================
# GLUCOSE TRANSFORMER PROJECT — .gitignore
# ============================================================

# ------------------------------------------------------------
# MODEL CHECKPOINTS
# Too large for normal Git history. Recreate them by re-running
# the relevant training entry points or store them separately.
# ------------------------------------------------------------
**/checkpoints/
**/best_model.pt
**/best_lstm_model.pt
**/best_meta_model.pt
**/noninvasive_best.pt
**/checkpoint_epoch_*.pt
**/final_model.pt
**/pretrained_*.pt
**/*.pth

# ------------------------------------------------------------
# RAW DATASETS
# OhioT1DM is access-controlled and must not be redistributed.
# PhysioCGM and any other raw wearable exports are too large for
# GitHub and may have their own licensing terms.
# ------------------------------------------------------------
**/data/raw/
**/data/raw/**

# ------------------------------------------------------------
# PROCESSED DATA TENSORS
# Generated from preprocessing or simulation. These binary files
# are reproducible and should stay out of Git history.
# ------------------------------------------------------------
**/data/processed/
**/data/processed/**
**/*.pt
!**/data/examples/*.pt

# ------------------------------------------------------------
# SYNTHETIC COHORT DATA
# Large generated user-level datasets from Part D and the
# non-invasive project. Rebuild locally when needed.
# ------------------------------------------------------------
**/data/synthetic_cohort/
**/data/synthetic_cohort/**

# ------------------------------------------------------------
# PYTHON CACHE AND COMPILED FILES
# Machine-specific interpreter artifacts.
# ------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ------------------------------------------------------------
# VIRTUAL ENVIRONMENTS AND BUILD OUTPUTS
# Dependencies are captured in requirements files instead.
# ------------------------------------------------------------
venv/
env/
.env/
.venv/
ENV/
env.bak/
venv.bak/
*.egg-info/
dist/
build/

# ------------------------------------------------------------
# JUPYTER CHECKPOINTS
# Notebook autosave artifacts, never source of truth.
# ------------------------------------------------------------
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ------------------------------------------------------------
# IDE, EDITOR, AND OPERATING SYSTEM FILES
# Local machine preferences should not be published.
# ------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# ------------------------------------------------------------
# EXPERIMENT TRACKING AND LOGGING
# Regenerated by rerunning experiments.
# ------------------------------------------------------------
wandb/
**/wandb/
*.wandb
runs/
**/runs/
logs/
**/logs/
*.tfevents.*

# ------------------------------------------------------------
# TEMPORARY, CACHE, AND SANDBOX WORKING FILES
# Local scratch state used during development.
# ------------------------------------------------------------
*.tmp
*.temp
tmp/
temp/
.cache/
**/.cache/
.codex_tmp/

# ------------------------------------------------------------
# GENERATED FIGURES
# Keep curated documentation figures under docs/figures/, but
# ignore run-generated PNG/PDF/SVG artifacts elsewhere.
# ------------------------------------------------------------
**/figures/*.png
**/figures/*.pdf
**/figures/*.svg
**/figures/**/*.png
**/figures/**/*.pdf
**/figures/**/*.svg
!docs/figures/*.png
!docs/figures/*.svg

# ------------------------------------------------------------
# LARGE RAW PREDICTION EXPORTS
# Summary CSV/JSON files may be committed; per-window dumps stay out.
# ------------------------------------------------------------
**/results/raw_predictions_*.csv
**/results/per_window_*.csv
**/results/predictions_*.csv

# ------------------------------------------------------------
# LOCAL SMOKE-RUN AND DRAFT NON-INVASIVE ARTIFACTS
# These files reflect partial local runs and living notes rather
# than a final reproducible experiment package.
# ------------------------------------------------------------
noninvasive_glucose/results/
noninvasive_glucose/results/**
noninvasive_glucose/NONINVASIVE_LIVING_EXPLANATION.md

# ------------------------------------------------------------
# ENVIRONMENT AND SECRET FILES
# Never commit credentials or machine-local configs.
# ------------------------------------------------------------
.env.local
.env.*.local
*.key
*.pem
secrets.py
config_secret.py

# ------------------------------------------------------------
# AUTHORING PROMPTS AND SCRATCH COPIES
# These are useful while developing in the IDE, but they are not
# part of the clean publication-facing repository.
# ------------------------------------------------------------
prompts/
PartA/
PartB/
PartC/
PartD/
PartE/
LIVING_EXPLANATION.md
glucose_transformer/PART_A_EXPLANATION.md
glucose_transformer/PART_B_EXPLANATION.md
glucose_transformer/PART_C_EXPLANATION.md
glucose_transformer/PART_D_EXPLANATION.md
glucose_transformer/PART_E_EXPLANATION.md
